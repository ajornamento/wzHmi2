{
  "name": "wzhmi2",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:editor\" \"npm run dev:viewer\"",
    "dev:editor": "npm run dev --workspace=apps/editor",
    "dev:viewer": "npm run dev --workspace=apps/viewer",
    "dev:server": "npm run dev --workspace=apps/dev-server",
    "build": "npm run build --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.0"
  }
}
